{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow main window to invoke custom commands and store plugin, including from remote GitHub Pages URL",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://mrzhaobh.github.io/*",
      "http://*",
      "https://*"
    ]
  },
  "permissions": [
    "core:default",
    "store:default"
  ]
}
